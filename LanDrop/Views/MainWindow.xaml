<Window x:Class="LanDrop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:LanDrop"
        xmlns:cv="clr-namespace:LanDrop.Converters"
        xmlns:vm="clr-namespace:LanDrop.ViewModels"
        Title="LanDrop" Width="980" Height="680"
        MinWidth="860" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        Icon="/Resources/LanDrop.ico"
        WindowStyle="SingleBorderWindow"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      UseAeroCaptionButtons="False"
                      GlassFrameThickness="0,0,0,1"
                      NonClientFrameEdges="None"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <cv:BytesToStringConverter           x:Key="BytesConv"/>
        <cv:SpeedConverter                   x:Key="SpeedConv"/>
        <cv:TimeSpanToEtaConverter           x:Key="EtaConv"/>
        <cv:PercentConverter                 x:Key="PctConv"/>
        <cv:BoolToVisibilityConverter        x:Key="BoolVis"/>
        <cv:InverseBoolToVisibilityConverter x:Key="InvBoolVis"/>
        <cv:InverseBooleanConverter          x:Key="InvBool"/>
        <cv:TransferStateToColorConverter    x:Key="StateColor"/>
        <cv:TransferStateToLabelConverter    x:Key="StateLabel"/>
        <cv:IsActiveTransferConverter        x:Key="IsActive"/>
        <cv:IsActiveToVisibilityConverter    x:Key="IsActiveVis"/>
        <cv:CanSendConverter                 x:Key="CanSend"/>
        <cv:IsPausedToVisibilityConverter    x:Key="IsPaused"/>
        <cv:ProgressWidthConverter           x:Key="ProgWidth"/>
        <cv:IntEqualConverter                x:Key="IntEqual"/>

        <!-- ══ NAV BUTTON ══ -->
        <Style x:Key="NavBtn" TargetType="RadioButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontFamily"      Value="{DynamicResource BodyFont}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource SurfaceElevBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource SurfaceAltBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ PRIMARY BUTTON ══ -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontFamily"      Value="{DynamicResource BodyFont}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Effect"          Value="{DynamicResource ButtonShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource PrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed"  Value="True">
                                <Setter Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"  Value="False">
                                <Setter Property="Opacity" Value="0.38"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ GHOST BUTTON ══ -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontFamily"      Value="{DynamicResource BodyFont}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="12,7"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource SurfaceAltBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed"  Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"  Value="False">
                                <Setter Property="Opacity" Value="0.38"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
            <Setter Property="Foreground"  Value="{DynamicResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
        </Style>

        <!-- ══ ICON BUTTON ══ -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="6,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource SurfaceAltBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ CARD ══ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="18"/>
            <Setter Property="Effect"          Value="{DynamicResource CardShadow}"/>
        </Style>

        <!-- ══ FLAT TEXTBOX ══ -->
        <Style x:Key="FlatBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontFamily"      Value="{DynamicResource MonoFont}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="SelectionBrush"  Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ DEVICE LIST ITEM ══ -->
        <Style x:Key="DeviceItem" TargetType="ListBoxItem">
            <Setter Property="Padding"         Value="10,9"/>
            <Setter Property="Margin"          Value="0,1"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" BorderThickness="1"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{DynamicResource SurfaceAltBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{DynamicResource PrimarySubtleBrush}"/>
                                <Setter TargetName="Bg" Property="BorderBrush"
                                        Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ TOAST ITEM ══ -->
        <DataTemplate x:Key="ToastTemplate" DataType="{x:Type vm:ToastViewModel}">
            <Border Margin="0,6,0,0"
                    Background="{DynamicResource ToastBgBrush}"
                    BorderBrush="{DynamicResource ToastBorderBrush}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="14,12"
                    Effect="{DynamicResource ToastShadow}"
                    MinWidth="300" MaxWidth="360">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="24" Height="24"
                            CornerRadius="12" VerticalAlignment="Top"
                            Margin="0,1,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource PrimarySubtleBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Type}" Value="success">
                                        <Setter Property="Background" Value="{DynamicResource SuccessSubtleBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Type}" Value="error">
                                        <Setter Property="Background" Value="{DynamicResource DangerSubtleBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding Icon}" FontSize="12"
                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="success">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="error">
                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="{Binding Title}"
                                   FontFamily="{DynamicResource BodyFont}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding Message}"
                                   FontFamily="{DynamicResource BodyFont}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <!-- ══════════════════════════════ ROOT ═══════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- ══════════════ HEADER (custom title bar) ══════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource BackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="30" Height="30" CornerRadius="8"
                            Background="{DynamicResource PrimaryBrush}" Margin="0,0,10,0">
                        <TextBlock Text="⇅" FontSize="16" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="LanDrop"
                               FontFamily="{DynamicResource DisplayFont}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Nav tabs -->
                <Border Grid.Column="1" HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource SurfaceAltBrush}"
                        CornerRadius="9" Padding="3">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Style="{StaticResource NavBtn}"
                                     IsChecked="{Binding ActiveTab,
                                         Converter={StaticResource IntEqual},
                                         ConverterParameter=0, Mode=TwoWay}"
                                     GroupName="Nav">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↑" FontSize="13" Margin="0,0,5,0"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"/>
                                <TextBlock Text="Send"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavBtn}" Margin="2,0,0,0"
                                     IsChecked="{Binding ActiveTab,
                                         Converter={StaticResource IntEqual},
                                         ConverterParameter=1, Mode=TwoWay}"
                                     GroupName="Nav">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↓" FontSize="13" Margin="0,0,5,0"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"/>
                                <TextBlock Text="Receive"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavBtn}" Margin="2,0,0,0"
                                     IsChecked="{Binding ActiveTab,
                                         Converter={StaticResource IntEqual},
                                         ConverterParameter=2, Mode=TwoWay}"
                                     GroupName="Nav">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⊕" FontSize="13" Margin="0,0,5,0"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"/>
                                <TextBlock Text="WiFi Direct"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavBtn}" Margin="2,0,0,0"
                                     IsChecked="{Binding ActiveTab,
                                         Converter={StaticResource IntEqual},
                                         ConverterParameter=3, Mode=TwoWay}"
                                     GroupName="Nav">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="☰" FontSize="13" Margin="0,0,5,0"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"/>
                                <TextBlock Text="History"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <!-- Right controls + custom window buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="{Binding LocalDeviceName}"
                                   FontFamily="{DynamicResource BodyFont}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding LocalIpAddress}"
                                   FontFamily="{DynamicResource MonoFont}"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                    <Border CornerRadius="10" Padding="9,4" Margin="0,0,8,0"
                            Background="{DynamicResource SuccessSubtleBrush}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="{DynamicResource SuccessBrush}"
                                     Margin="0,0,6,0"/>
                            <TextBlock Text="Listening"
                                       FontFamily="{DynamicResource BodyFont}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SuccessBrush}"/>
                        </StackPanel>
                    </Border>
                    <!-- Theme toggle -->
                    <Button Style="{StaticResource IconBtn}"
                            Command="{Binding ToggleThemeCommand}"
                            ToolTip="Toggle theme" Padding="8,6"
                            Margin="0,0,4,0">
                        <TextBlock FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="☀"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                            <Setter Property="Text" Value="🌙"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <!-- Custom window chrome buttons -->
                    <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                        <!-- Minimize -->
                        <Button x:Name="BtnMinimize"
                                Width="32" Height="32" Padding="0"
                                BorderThickness="0"
                                Background="Transparent"
                                Cursor="Hand"
                                Click="BtnMinimize_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                ToolTip="Minimize">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                                        <TextBlock Text="─" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{DynamicResource SurfaceAltBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Maximize / Restore -->
                        <Button x:Name="BtnMaximize"
                                Width="32" Height="32" Padding="0"
                                BorderThickness="0"
                                Background="Transparent"
                                Cursor="Hand"
                                Click="BtnMaximize_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                ToolTip="Maximize">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                                        <TextBlock Text="□" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{DynamicResource SurfaceAltBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Close -->
                        <Button x:Name="BtnClose"
                                Width="32" Height="32" Padding="0"
                                BorderThickness="0"
                                Background="Transparent"
                                Cursor="Hand"
                                Click="BtnClose_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                ToolTip="Close">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                                        <TextBlock Text="✕" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{DynamicResource DangerBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════ BODY ════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="16,12,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Devices ──────────────────────────────────────────── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="NEARBY DEVICES"
                           FontFamily="{DynamicResource BodyFont}"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="2,0,0,8"/>

                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="6">
                    <Grid>
                        <ListBox ItemsSource="{Binding DiscoveredDevices}"
                                 SelectedItem="{Binding SelectedDevice}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemContainerStyle="{StaticResource DeviceItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28"
                                                CornerRadius="7"
                                                Background="{DynamicResource SurfaceAltBrush}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="⬡" FontSize="14"
                                                       Foreground="{DynamicResource PrimaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="9,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DeviceName}"
                                                       FontFamily="{DynamicResource BodyFont}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Address}"
                                                       FontFamily="{DynamicResource MonoFont}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <Ellipse Grid.Column="2" Width="7" Height="7"
                                                 Fill="{DynamicResource SuccessBrush}"
                                                 VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Empty state -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Margin="0,20">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DiscoveredDevices.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="○" FontSize="28"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Scanning…"
                                       FontFamily="{DynamicResource BodyFont}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Manual IP -->
                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                    <TextBlock Text="MANUAL IP"
                               FontFamily="{DynamicResource BodyFont}"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="2,0,0,6"/>
                    <TextBox Style="{StaticResource FlatBox}"
                             Text="{Binding ManualIpInput, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SendFilesCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </StackPanel>
            </Grid>

            <!-- ── RIGHT PANEL ─────────────────────────────────────────────── -->
            <Grid Grid.Column="2">

                <!-- SEND -->
                <Grid Visibility="{Binding IsSendMode, Converter={StaticResource BoolVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="FILES TO SEND"
                               FontFamily="{DynamicResource BodyFont}"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="2,0,0,8"/>

                    <!-- Drop zone -->
                    <Border Grid.Row="1" Style="{StaticResource Card}"
                            Background="{DynamicResource DropZoneBrush}"
                            BorderBrush="{DynamicResource DropZoneBorderBrush}">
                        <Grid>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding QueuedFiles.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="↑" FontSize="40"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           FontWeight="Thin"/>
                                <TextBlock Text="Drop files or folders here"
                                           FontFamily="{DynamicResource BodyFont}"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,4"/>
                                <TextBlock Text="or use the buttons below"
                                           FontFamily="{DynamicResource BodyFont}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <ListView ItemsSource="{Binding QueuedFiles}"
                                      Background="Transparent" BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.Style>
                                    <Style TargetType="ListView">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding QueuedFiles.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.Style>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,7" Margin="0,2"
                                                Background="{DynamicResource SurfaceBrush}"
                                                CornerRadius="7">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="28"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="◻"
                                                           FontSize="16"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding RelativePath}"
                                                           FontFamily="{DynamicResource BodyFont}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding SizeBytes, Converter={StaticResource BytesConv}}"
                                                           FontFamily="{DynamicResource MonoFont}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>
                                                <Button Grid.Column="3" Content="✕"
                                                        FontSize="11" Width="20" Height="20"
                                                        Padding="0" Background="Transparent"
                                                        BorderThickness="0" Cursor="Hand"
                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                        Command="{Binding DataContext.RemoveFileCommand,
                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <!-- File action buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Style="{StaticResource GhostBtn}" Content="+ Add Files"
                                Command="{Binding AddFilesCommand}" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource GhostBtn}" Content="+ Add Folder"
                                Command="{Binding AddFolderCommand}" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource DangerBtn}" Content="Clear"
                                Command="{Binding ClearFilesCommand}"/>
                    </StackPanel>

                    <!-- Send button -->
                    <Button Grid.Row="3" Style="{StaticResource PrimaryBtn}"
                            Content="Send Files →"
                            FontSize="14" Padding="0,13" Margin="0,10,0,0"
                            Command="{Binding SendFilesCommand}"
                            IsEnabled="{Binding TransferState, Converter={StaticResource CanSend}}"/>
                </Grid>

                <!-- RECEIVE -->
                <Grid Visibility="{Binding IsReceiveMode, Converter={StaticResource BoolVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="RECEIVE MODE"
                               FontFamily="{DynamicResource BodyFont}"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="2,0,0,8"/>

                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center" MaxWidth="400">
                            <TextBlock Text="↓" FontSize="48" FontWeight="Thin"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Ready to Receive"
                                       FontFamily="{DynamicResource DisplayFont}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,14,0,8"/>
                            <TextBlock Text="Listening for incoming transfers from any LanDrop device on your network. Transfers are accepted automatically."
                                       FontFamily="{DynamicResource BodyFont}"
                                       FontSize="13" TextAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"/>

                            <!-- Save folder -->
                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    CornerRadius="9" Padding="14,10"
                                    Margin="0,22,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="SAVE TO"
                                                   FontFamily="{DynamicResource BodyFont}"
                                                   FontSize="9" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding Source={x:Static local:App.Settings},
                                                       Path=ReceiveSavePath}"
                                                   FontFamily="{DynamicResource MonoFont}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource GhostBtn}"
                                            Content="Change"
                                            Command="{Binding ChangeSaveFolderCommand}"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- WIFI DIRECT -->
                <ScrollViewer Visibility="{Binding IsWifiDirectMode, Converter={StaticResource BoolVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="WifiDirectGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="WIFI DIRECT"
                                   FontFamily="{DynamicResource BodyFont}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="2,0,0,8"/>

                        <!-- Credentials card -->
                        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- SSID row -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Network"
                                               FontFamily="{DynamicResource BodyFont}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1"
                                             x:Name="SsidBox"
                                             Style="{StaticResource FlatBox}"
                                             FontSize="14" FontWeight="SemiBold"
                                             VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Style="{StaticResource IconBtn}"
                                            Content="⧉" FontSize="14"
                                            Click="CopySsid_Click"
                                            ToolTip="Copy network name"/>
                                </Grid>

                                <!-- Password row -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Password"
                                               FontFamily="{DynamicResource BodyFont}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1"
                                             x:Name="PassBox"
                                             Style="{StaticResource FlatBox}"
                                             FontSize="14" FontWeight="SemiBold"
                                             Foreground="{DynamicResource PrimaryBrush}"
                                             VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Style="{StaticResource IconBtn}"
                                            Content="⧉" FontSize="14"
                                            Click="CopyPassword_Click"
                                            ToolTip="Copy password"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Steps card -->
                        <Border Grid.Row="2"
                                Background="{DynamicResource DropZoneBrush}"
                                BorderBrush="{DynamicResource DropZoneBorderBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="16,14" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="How to connect the other PC"
                                           FontFamily="{DynamicResource BodyFont}"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,10"/>
                                <TextBlock FontFamily="{DynamicResource BodyFont}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,6">
                                    <Run FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}">1.</Run>
                                    <Run Text=" Click Start Hotspot below"/>
                                </TextBlock>
                                <TextBlock FontFamily="{DynamicResource BodyFont}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,6">
                                    <Run FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}">2.</Run>
                                    <Run Text=" On the other PC → open WiFi → connect to the network above"/>
                                </TextBlock>
                                <TextBlock FontFamily="{DynamicResource BodyFont}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,6">
                                    <Run FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}">3.</Run>
                                    <Run Text=" Open LanDrop on that PC — devices discover each other"/>
                                </TextBlock>
                                <TextBlock FontFamily="{DynamicResource BodyFont}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap">
                                    <Run FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}">4.</Run>
                                    <Run Text=" Send files normally. No internet required."/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Hotspot button -->
                        <Button Grid.Row="3"
                                x:Name="HotspotToggleBtn"
                                HorizontalAlignment="Stretch"
                                FontSize="14" FontWeight="SemiBold"
                                Foreground="White" BorderThickness="0"
                                Padding="0,13" Margin="0,0,0,10"
                                Cursor="Hand"
                                Click="HotspotToggle_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="8"
                                                        Padding="{TemplateBinding Padding}">
                                                    <TextBlock x:Name="BtnLabel"
                                                               Text="Start Hotspot"
                                                               FontSize="14" FontWeight="SemiBold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Status -->
                        <Border Grid.Row="4" CornerRadius="8" Padding="12,9">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="HotspotStatusDot"
                                         Width="7" Height="7"
                                         Fill="{DynamicResource TextMutedBrush}"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center"/>
                                <TextBlock x:Name="HotspotStatusText"
                                           Text="Off — click Start to create a direct connection"
                                           FontFamily="{DynamicResource BodyFont}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <!-- HISTORY -->
                <Grid Visibility="{Binding IsHistoryMode, Converter={StaticResource BoolVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="2,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="TRANSFER HISTORY"
                                   FontFamily="{DynamicResource BodyFont}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Style="{StaticResource GhostBtn}"
                                Content="Clear All"
                                Command="{Binding ClearHistoryCommand}"/>
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="6">
                        <Grid>
                            <!-- Empty state -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding History.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="○"
                                           FontSize="28"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="No transfers yet"
                                           FontFamily="{DynamicResource BodyFont}"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <ListView ItemsSource="{Binding History}"
                                      Background="Transparent" BorderThickness="0">
                                <ListView.Style>
                                    <Style TargetType="ListView">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding History.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.Style>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,8" Margin="0,2"
                                                Background="{DynamicResource SurfaceBrush}"
                                                CornerRadius="7">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Direction badge -->
                                                <Border Grid.Column="0" Width="28" Height="28"
                                                        CornerRadius="7"
                                                        Background="{DynamicResource SurfaceAltBrush}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Direction}"
                                                               FontFamily="{DynamicResource MonoFont}"
                                                               FontSize="9" FontWeight="Bold"
                                                               Foreground="{Binding DirectionColor}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <!-- File info -->
                                                <StackPanel Grid.Column="1" Margin="10,0,0,0"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}"
                                                               FontFamily="{DynamicResource BodyFont}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding PeerName}"
                                                                   FontFamily="{DynamicResource BodyFont}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                        <TextBlock Text=" · "
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                                        <TextBlock Text="{Binding DisplaySize}"
                                                                   FontFamily="{DynamicResource MonoFont}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <!-- Time -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding DisplayTime}"
                                                           FontFamily="{DynamicResource MonoFont}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>
        </Grid>

        <!-- ══ TRANSFER PROGRESS STRIP ════════════════════════════════════ -->
        <Border Grid.Row="1" VerticalAlignment="Bottom"
                Margin="16,0,16,16"
                Visibility="{Binding TransferState, Converter={StaticResource IsActiveVis}}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="10"
                Padding="18,14"
                Effect="{DynamicResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- File + badge -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding CurrentFileName}"
                                   FontFamily="{DynamicResource BodyFont}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding TransferredBytes, Converter={StaticResource BytesConv}}"
                                       FontFamily="{DynamicResource MonoFont}" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text=" / " FontSize="11" Margin="3,0"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBlock Text="{Binding TotalBytes, Converter={StaticResource BytesConv}}"
                                       FontFamily="{DynamicResource MonoFont}" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="1" CornerRadius="6" Padding="9,4"
                            Background="{DynamicResource SurfaceAltBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding TransferState, Converter={StaticResource StateLabel}}"
                                   FontFamily="{DynamicResource BodyFont}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{Binding TransferState, Converter={StaticResource StateColor}}"/>
                    </Border>
                </Grid>

                <!-- Progress bar -->
                <Border Grid.Row="2" x:Name="ProgressTrack"
                        Height="6" CornerRadius="3"
                        Background="{DynamicResource ProgressTrackBrush}">
                    <Border Height="6" CornerRadius="3"
                            HorizontalAlignment="Left"
                            Background="{DynamicResource ProgressFillBrush}">
                        <Border.Width>
                            <MultiBinding Converter="{StaticResource ProgWidth}">
                                <Binding Path="ProgressPercent"/>
                                <Binding Path="ActualWidth" ElementName="ProgressTrack"/>
                            </MultiBinding>
                        </Border.Width>
                    </Border>
                </Border>

                <!-- Stats + controls -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="SPEED" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBlock Text="{Binding SpeedBytesPerSec, Converter={StaticResource SpeedConv}}"
                                       FontFamily="{DynamicResource MonoFont}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="ETA" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBlock Text="{Binding Eta, Converter={StaticResource EtaConv}}"
                                       FontFamily="{DynamicResource MonoFont}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="DONE" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBlock Text="{Binding ProgressPercent, Converter={StaticResource PctConv}}"
                                       FontFamily="{DynamicResource MonoFont}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource GhostBtn}" Content="Pause"
                                Command="{Binding PauseTransferCommand}"
                                Margin="0,0,8,0"
                                Visibility="{Binding TransferState, Converter={StaticResource IsActiveVis}}"/>
                        <Button Style="{StaticResource GhostBtn}" Content="Resume"
                                Command="{Binding ResumeTransferCommand}"
                                Margin="0,0,8,0"
                                Visibility="{Binding TransferState, Converter={StaticResource IsPaused}}"/>
                        <Button Style="{StaticResource DangerBtn}" Content="Cancel"
                                Command="{Binding CancelTransferCommand}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ══ COMPLETED/FAILED BANNER ════════════════════════════════════ -->
        <Border Grid.Row="1" VerticalAlignment="Bottom"
                Margin="16,0,16,16"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="1" CornerRadius="10"
                Padding="18,12"
                Effect="{DynamicResource CardShadow}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding TransferState}" Value="Completed">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding TransferState}" Value="Failed">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding TransferState}" Value="Cancelled">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           FontFamily="{DynamicResource BodyFont}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Style="{StaticResource GhostBtn}"
                        Content="Dismiss"
                        Command="{Binding ResetTransferCommand}"/>
            </Grid>
        </Border>

        <!-- ══ HASHING OVERLAY ════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Background="#CC000000"
              Visibility="{Binding IsHashing, Converter={StaticResource BoolVis}}">
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12"
                    Padding="36,28"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Effect="{DynamicResource CardShadow}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="⟳" FontSize="32"
                               Foreground="{DynamicResource PrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Verifying files…"
                               FontFamily="{DynamicResource BodyFont}"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding HashingStatus}"
                               FontFamily="{DynamicResource BodyFont}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ TOAST NOTIFICATIONS (bottom-right) ════════════════════════ -->
        <ItemsControl Grid.Row="0" Grid.RowSpan="3"
                      ItemsSource="{Binding Toasts}"
                      ItemTemplate="{StaticResource ToastTemplate}"
                      VerticalAlignment="Bottom"
                      HorizontalAlignment="Right"
                      Margin="0,0,16,44"
                      Panel.ZIndex="100"/>

        <!-- ══ STATUS BAR ══════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           FontFamily="{DynamicResource BodyFont}"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Text="v1.0.0"
                           FontFamily="{DynamicResource MonoFont}"
                           FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>
