<UserControl x:Class="LanDrop.Views.WiFiDirectPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LanDrop"
             xmlns:cv="clr-namespace:LanDrop.Converters">

    <UserControl.Resources>
        <cv:BoolToVisibilityConverter        x:Key="BoolVis"/>
        <cv:InverseBooleanConverter          x:Key="InvBool"/>
        <cv:InverseBoolToVisibilityConverter x:Key="InvBoolVis"/>

        <!-- Primary button style (inline to avoid dependency on Window resources) -->
        <Style x:Key="HotBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="18,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small icon button -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource SurfaceAltBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Credentials card -->
            <RowDefinition Height="Auto"/>   <!-- Instructions card -->
            <RowDefinition Height="Auto"/>   <!-- Toggle button -->
            <RowDefinition Height="Auto"/>   <!-- Status -->
        </Grid.RowDefinitions>

        <!-- ── Section header ─────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="WIFI DIRECT MODE"
                       FontFamily="{DynamicResource BodyFont}"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource TextMutedBrush}"/>
            <TextBlock Text="Connect two PCs without a router or internet"
                       FontFamily="{DynamicResource BodyFont}"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,3,0,0"/>
        </StackPanel>

        <!-- ── Credentials card ───────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="12"
                Padding="18,14" Margin="0,0,0,12"
                Effect="{DynamicResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- SSID row -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Network"
                               FontFamily="{DynamicResource BodyFont}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Ssid}"
                               FontFamily="{DynamicResource MonoFont}"
                               FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Style="{StaticResource IconBtn}"
                            Content="📋" FontSize="14"
                            Command="{Binding CopySsidCommand}"
                            ToolTip="Copy network name"/>
                </Grid>

                <!-- Password row -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Password"
                               FontFamily="{DynamicResource BodyFont}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center"/>

                    <!-- Shown password -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding Password}"
                               FontFamily="{DynamicResource MonoFont}"
                               FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="{Binding ShowPassword, Converter={StaticResource BoolVis}}"/>

                    <!-- Hidden password -->
                    <TextBlock Grid.Column="1"
                               Text="••••••••••"
                               FontSize="18"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               Visibility="{Binding ShowPassword, Converter={StaticResource InvBoolVis}}"/>

                    <Button Grid.Column="2" Style="{StaticResource IconBtn}"
                            Content="👁" FontSize="13"
                            Command="{Binding ToggleShowPasswordCommand}"
                            ToolTip="Show/hide password"/>
                    <Button Grid.Column="3" Style="{StaticResource IconBtn}"
                            Content="📋" FontSize="14"
                            Command="{Binding CopyPasswordCommand}"
                            ToolTip="Copy password"/>
                    <Button Grid.Column="4" Style="{StaticResource IconBtn}"
                            Content="🔄" FontSize="13"
                            Command="{Binding RegeneratePasswordCommand}"
                            IsEnabled="{Binding IsStopped}"
                            ToolTip="Generate new password"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ── Instructions card ─────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{DynamicResource DropZoneBrush}"
                BorderBrush="{DynamicResource DropZoneBorderBrush}"
                BorderThickness="1" CornerRadius="10"
                Padding="16,12" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="How to connect the other PC:"
                           FontFamily="{DynamicResource BodyFont}"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>

                <!-- Step 1 -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="18" Height="18"
                            CornerRadius="9" Background="{DynamicResource PrimaryBrush}"
                            VerticalAlignment="Top" Margin="0,1,0,0">
                        <TextBlock Text="1" FontSize="10" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="Start the hotspot below on THIS PC"
                               FontFamily="{DynamicResource BodyFont}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="6,0,0,0"/>
                </Grid>

                <!-- Step 2 -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="18" Height="18"
                            CornerRadius="9" Background="{DynamicResource PrimaryBrush}"
                            VerticalAlignment="Top" Margin="0,1,0,0">
                        <TextBlock Text="2" FontSize="10" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1"
                               FontFamily="{DynamicResource BodyFont}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="6,0,0,0">
                        <Run Text="On the OTHER PC → Connect to WiFi: "/>
                        <Run Text="{Binding Ssid}" FontWeight="Bold"
                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </TextBlock>
                </Grid>

                <!-- Step 3 -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="18" Height="18"
                            CornerRadius="9" Background="{DynamicResource PrimaryBrush}"
                            VerticalAlignment="Top" Margin="0,1,0,0">
                        <TextBlock Text="3" FontSize="10" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="Open LanDrop on the other PC — it will discover this PC automatically"
                               FontFamily="{DynamicResource BodyFont}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="6,0,0,0"/>
                </Grid>

                <!-- Step 4 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="18" Height="18"
                            CornerRadius="9" Background="{DynamicResource PrimaryBrush}"
                            VerticalAlignment="Top" Margin="0,1,0,0">
                        <TextBlock Text="4" FontSize="10" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="Send files normally — no internet needed!"
                               FontFamily="{DynamicResource BodyFont}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="6,0,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Toggle button ──────────────────────────────────────────── -->
        <Button Grid.Row="3"
                Content="{Binding ToggleButtonText}"
                Command="{Binding ToggleHotspotCommand}"
                HorizontalAlignment="Stretch"
                FontSize="14" FontWeight="SemiBold"
                Foreground="White" BorderThickness="0"
                Padding="0,12" Margin="0,0,0,10"
                Cursor="Hand">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#22C55E"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                            <Setter Property="Background" Value="#EF4444"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="Background" Value="#F59E0B"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- ── Status bar ─────────────────────────────────────────────── -->
        <Border Grid.Row="4" CornerRadius="8" Padding="12,8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                            <Setter Property="Background" Value="#DCFCE7"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                         VerticalAlignment="Center">
                    <Ellipse.Fill>
                        <SolidColorBrush Color="{Binding StateColor}"/>
                    </Ellipse.Fill>
                </Ellipse>
                <TextBlock Text="{Binding StatusText}"
                           FontFamily="{DynamicResource BodyFont}"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Not supported warning ─────────────────────────────────── -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="#CC000000" CornerRadius="12"
                Visibility="{Binding IsSupported, Converter={StaticResource InvBoolVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                <TextBlock Text="⚠" FontSize="36" HorizontalAlignment="Center"/>
                <TextBlock Text="WiFi Direct Not Supported"
                           FontSize="15" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,10,0,6"/>
                <TextBlock Text="Your WiFi adapter does not support hosted networks. Try updating your WiFi drivers."
                           FontSize="12" Foreground="#CBD5E1"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
