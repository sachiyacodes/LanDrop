<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══ YOUR PALETTE — Deep dark teal ══
         Text:       #eceeee
         Background: #040606
         Primary:    #50adaf
         Secondary:  #206465
         Accent:     #22a8aa
    -->
    <SolidColorBrush x:Key="BackgroundBrush"      Color="#040606"/>
    <SolidColorBrush x:Key="SurfaceBrush"         Color="#0a0f0f"/>
    <SolidColorBrush x:Key="SurfaceAltBrush"      Color="#0f1616"/>
    <SolidColorBrush x:Key="SurfaceElevBrush"     Color="#162020"/>
    <SolidColorBrush x:Key="BorderBrush"          Color="#1a2828"/>
    <SolidColorBrush x:Key="BorderSubtleBrush"    Color="#0f1616"/>
    <SolidColorBrush x:Key="PrimaryBrush"         Color="#50adaf"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush"    Color="#6bc0c2"/>
    <SolidColorBrush x:Key="PrimarySubtleBrush"   Color="#0d2525"/>
    <SolidColorBrush x:Key="AccentBrush"          Color="#22a8aa"/>
    <SolidColorBrush x:Key="SecondaryBrush"       Color="#206465"/>
    <SolidColorBrush x:Key="SuccessBrush"         Color="#50adaf"/>
    <SolidColorBrush x:Key="SuccessSubtleBrush"   Color="#0d2525"/>
    <SolidColorBrush x:Key="WarnBrush"            Color="#c4a44a"/>
    <SolidColorBrush x:Key="DangerBrush"          Color="#e05555"/>
    <SolidColorBrush x:Key="DangerSubtleBrush"    Color="#2a0d0d"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="#eceeee"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="#7a9090"/>
    <SolidColorBrush x:Key="TextMutedBrush"       Color="#2e4444"/>
    <SolidColorBrush x:Key="ProgressTrackBrush"   Color="#0f1616"/>
    <SolidColorBrush x:Key="ProgressFillBrush"    Color="#50adaf"/>
    <SolidColorBrush x:Key="DropZoneBrush"        Color="#060e0e"/>
    <SolidColorBrush x:Key="DropZoneBorderBrush"  Color="#206465"/>
    <SolidColorBrush x:Key="ToastBgBrush"         Color="#0a0f0f"/>
    <SolidColorBrush x:Key="ToastBorderBrush"     Color="#1a2828"/>
    <SolidColorBrush x:Key="InputBgBrush"         Color="#040606"/>
    <SolidColorBrush x:Key="TitleBarBrush"        Color="#040606"/>

    <FontFamily x:Key="DisplayFont">Segoe UI Variable Display, Segoe UI Semibold, sans-serif</FontFamily>
    <FontFamily x:Key="BodyFont">Segoe UI Variable Text, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Code, Consolas, monospace</FontFamily>

    <DropShadowEffect x:Key="CardShadow"   BlurRadius="24" ShadowDepth="3" Direction="270" Color="#000000" Opacity="0.6"/>
    <DropShadowEffect x:Key="ButtonShadow" BlurRadius="14" ShadowDepth="2" Direction="270" Color="#50adaf"  Opacity="0.3"/>
    <DropShadowEffect x:Key="ToastShadow"  BlurRadius="30" ShadowDepth="8" Direction="270" Color="#000000" Opacity="0.7"/>

</ResourceDictionary>
