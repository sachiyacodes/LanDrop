<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══ LIGHT MODE — Clean white with teal accents ══ -->
    <SolidColorBrush x:Key="BackgroundBrush"      Color="#f0f4f4"/>
    <SolidColorBrush x:Key="SurfaceBrush"         Color="#ffffff"/>
    <SolidColorBrush x:Key="SurfaceAltBrush"      Color="#f0f4f4"/>
    <SolidColorBrush x:Key="SurfaceElevBrush"     Color="#ffffff"/>
    <SolidColorBrush x:Key="BorderBrush"          Color="#d4e0e0"/>
    <SolidColorBrush x:Key="BorderSubtleBrush"    Color="#e8f0f0"/>
    <SolidColorBrush x:Key="PrimaryBrush"         Color="#50adaf"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush"    Color="#3d9799"/>
    <SolidColorBrush x:Key="PrimarySubtleBrush"   Color="#e0f4f4"/>
    <SolidColorBrush x:Key="AccentBrush"          Color="#22a8aa"/>
    <SolidColorBrush x:Key="SecondaryBrush"       Color="#206465"/>
    <SolidColorBrush x:Key="SuccessBrush"         Color="#206465"/>
    <SolidColorBrush x:Key="SuccessSubtleBrush"   Color="#e0f4f4"/>
    <SolidColorBrush x:Key="WarnBrush"            Color="#8a6800"/>
    <SolidColorBrush x:Key="DangerBrush"          Color="#c0392b"/>
    <SolidColorBrush x:Key="DangerSubtleBrush"    Color="#fdecea"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="#0a1414"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="#4a6868"/>
    <SolidColorBrush x:Key="TextMutedBrush"       Color="#8aabab"/>
    <SolidColorBrush x:Key="ProgressTrackBrush"   Color="#e0ecec"/>
    <SolidColorBrush x:Key="ProgressFillBrush"    Color="#50adaf"/>
    <SolidColorBrush x:Key="DropZoneBrush"        Color="#f4fafa"/>
    <SolidColorBrush x:Key="DropZoneBorderBrush"  Color="#50adaf"/>
    <SolidColorBrush x:Key="ToastBgBrush"         Color="#ffffff"/>
    <SolidColorBrush x:Key="ToastBorderBrush"     Color="#d4e0e0"/>
    <SolidColorBrush x:Key="InputBgBrush"         Color="#ffffff"/>
    <SolidColorBrush x:Key="TitleBarBrush"        Color="#ffffff"/>

    <FontFamily x:Key="DisplayFont">Segoe UI Variable Display, Segoe UI Semibold, sans-serif</FontFamily>
    <FontFamily x:Key="BodyFont">Segoe UI Variable Text, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Code, Consolas, monospace</FontFamily>

    <DropShadowEffect x:Key="CardShadow"   BlurRadius="18" ShadowDepth="2" Direction="270" Color="#206465" Opacity="0.08"/>
    <DropShadowEffect x:Key="ButtonShadow" BlurRadius="10" ShadowDepth="1" Direction="270" Color="#50adaf" Opacity="0.25"/>
    <DropShadowEffect x:Key="ToastShadow"  BlurRadius="22" ShadowDepth="5" Direction="270" Color="#206465" Opacity="0.12"/>

</ResourceDictionary>
